{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "rente.mitnorm.de"
        }
      ],
      "destination": "/rente-2026.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "pflegeimmobilie.mitnorm.de"
        }
      ],
      "destination": "/pflege-verl/:path*"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    }
  ]
}
